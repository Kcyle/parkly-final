<!doctype html>
<html lang="en">

<head>
   <meta charset="utf-8" />
   <title>Bookings</title>
   <link rel="stylesheet" href="/style.css">
   <link href="https://fonts.googleapis.com/css2?family=Open+Sans&display=swap" rel="stylesheet">
</head>

<body>
   <div id="page">
      <h1><a href="/">Parkly</a></h1>
      <h2>Bookings for <%= email %></h2>

      <% if (count === 1) { %>
         <p><%= count %> result.</p>
      <% } else { %>
         <p><%= count %> results.</p>
      <% } %>
      <%- table %>
      <br>
      <a href="/">HOME</a>
   </div>
</body>

</html>
